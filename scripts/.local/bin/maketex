#!/usr/bin/env sh

if [ "$#" -eq 0 ]; then
	echo "Usage: maketex <file.tex>"
	exit 1
fi

# If multiple files are passed, process independenly in parallel
if [ "$#" -gt 1 ]; then
	for file in "$@"; do
		if [ -f "$file" ]; then
			$0 "$file" &
		fi
	done
	wait
fi

tmpdir="/tmp"

tex_command="latexmk -pdf -synctex=1 -interaction=nonstopmode -output-directory=$tmpdir -aux-directory=$tmpdir"

if [ -f "$1" ]; then
	file="$(realpath "$1")"
	prefix="${file%.tex}"
	cd "$(dirname "$file")" # Needed to generate the tmp files besides the .tex file
	($tex_command "$file" && notify-send "LaTeX" "First pdflatex pass complete." 2>/dev/null)
	(biber --input-directory "$tmpdir" --output-directory "$tmpdir" "$prefix" && notify-send "LaTeX" "Biber pass complete." 2>/dev/null)
	($tex_command "$file" && notify-send "LaTeX" "Second pdflatex pass complete." 2>/dev/null)
	(makeglossaries -d "$tmpdir" "$(basename $prefix)" && $tex_command "$file" && notify-send "LaTeX" "Final pdflatex pass complete. PDF is ready.")
	mv "$tmpdir/$(basename "$prefix").pdf" "$(dirname "$file")/"
else
	# If number of parameters is 0, print usage
	if [ "$#" -eq 0 ]; then
		echo "Usage: maketex <file.tex>"
		return 1
	fi
	echo "File '$1' not found!"
	return 1
fi
