#!/usr/bin/env sh

if [ "$#" -eq 0 ]; then
	echo "Usage: maketex <file.tex>"
	exit 1
fi

# If multiple files are passed, process independenly in parallel
if [ "$#" -gt 1 ]; then
	for file in "$@"; do
		if [ -f "$file" ]; then
			$0 "$file" &
		fi
	done
	wait
fi

tex_command="latexmk -pdf -synctex=1 -interaction=nonstopmode"

if [ -f "$1" ]; then
	file="$(realpath "$1")"
	prefix="${file%.tex}"
	cd "$(dirname "$file")" # Needed to generate the tmp files besides the .tex file
	($tex_command "$file" && notify-send "LaTeX" "First pdflatex pass complete." 2>/dev/null)
	(biber $prefix && notify-send "LaTeX" "Biber pass complete." 2>/dev/null)
	($tex_command "$file" && notify-send "LaTeX" "Second pdflatex pass complete." 2>/dev/null)
	(makeglossaries "$(basename $prefix)" && $tex_command "$file" && notify-send "LaTeX" "Final pdflatex pass complete. PDF is ready.")
	# for ext in aux log bbl blg glo gls glg acr acn ist out alg bcf fls lof lot toc run.xml synctex.gz fdb_latexmk snm nav spl; do
    # 	[ -f $prefix.$ext ] && rm *.$ext 2>/dev/null
	# done
else
	# If number of parameters is 0, print usage
	if [ "$#" -eq 0 ]; then
		echo "Usage: maketex <file.tex>"
		return 1
	fi
	echo "File '$1' not found!"
	return 1
fi
